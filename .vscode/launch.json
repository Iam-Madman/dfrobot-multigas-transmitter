{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Black Magic Probe Attach",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "bmp",
            "gdbPath": "arm-none-eabi-gdb",
            "executable": "${workspaceFolder}/firmware/bluepill_firmware/build/Debug/Bluepill.elf",
            "BMPGDBSerialPort": "/dev/ttyBmpGdb",
            "interface": "swd",
            "device": "STM32F103CB",
            "cwd": "${workspaceFolder}/firmware/bluepill_firmware",
            "showDevDebugOutput": "raw",//remove if needed
            "preAttachCommands": [
                "mem 0x08000000 0x0800FFFF ro",
                "mem 0x20000000 0x20004FFF rw"
            ],
            "postAttachCommands": [
                "set mem inaccessible-by-default off",
                "set breakpoint auto-hw on"
            ],
            "overrideRestartCommands": [
                "interrupt",
                "set {int}0xE000ED0C = 0x05FA0004",//reset the device
                "continue"
            ],
        }
    ]
}